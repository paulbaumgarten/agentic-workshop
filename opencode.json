{
  "$schema": "https://opencode.ai/config.json",
  "name": "agentic-workshop",
  "version": "1.0.0",
  "providers": {
    "openai": {
      "model": "assistant",
      "apiKey": "${POE_API_KEY}"
    }
  },
  "agents": {
    "default": {
      "provider": "Poe",
      "instructions": "You are a helpful coding assistant."
    }
  },
  "permission": {
    "*": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls": true,
      "cat": true,
      "pwd": true,
      "cd": true,
      "find": true,
      "grep": true,
      "head": true,
      "tail": true,
      "wc": true,
      "sort": true,
      "uniq": true,
      "tee": true,
      "mkdir": true,
      "cp": true,
      "mv": true,
      "touch": true,
      "date": true,
      "echo": true,
      "printf": true
    },
    "git": "deny"
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", ".opencode/**"]
  },
  "scope": {
    "read": {
      "allow": ["${PROJECT_DIR}/**"],
      "deny": [".env"]
    }
  }
}