{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "poe-custom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Poe",
      "options": {
        "baseURL": "https://api.poe.com/v1",
        "apiKey": "${POE_API_KEY}"
      }
    }
  },
  "agent": {
    "default": {
      "provider": "poe-custom",
      "model": "poe/empiriolabs/deepseek-v4-flash-el",
      "instructions": "You are a helpful coding assistant."
    }
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "bash": {
      "ls": "allow",
      "cat": "allow",
      "pwd": "allow",
      "cd": "allow",
      "find": "allow",
      "grep": "allow",
      "head": "allow",
      "tail": "allow",
      "wc": "allow",
      "sort": "allow",
      "uniq": "allow",
      "tee": "allow",
      "mkdir": "allow",
      "cp": "allow",
      "mv": "allow",
      "touch": "allow",
      "date": "allow",
      "echo": "allow",
      "printf": "allow"
    },
    "git": "deny",
    "WebFetch": "ask"
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", ".opencode/**"]
  }
}