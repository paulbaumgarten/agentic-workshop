{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls": true,
      "cat": true,
      "pwd": true,
      "cd": true,
      "find": true,
      "grep": true,
      "head": true,
      "tail": true,
      "wc": true,
      "sort": true,
      "uniq": true,
      "tee": true,
      "mkdir": true,
      "cp": true,
      "mv": true,
      "touch": true,
      "date": true,
      "echo": true,
      "printf": true,
      "wc -l": true,
      "wc -c": true,
      "wc -w": true,
      "ls -la": true,
      "ls -lh": true,
      "ls -R": true
    },
    "git": "deny"
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", ".opencode/**"]
  },
  "scope": {
    "read": {
      "allow": ["${PROJECT_DIR}/**"],
      "deny": ["**", ".env"]
    }
  }
}
